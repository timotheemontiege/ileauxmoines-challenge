# ─── Serveur ───────────────────────────────────────────────
PORT=4000
# Origine(s) autorisée(s) pour CORS (front). Séparées par des virgules.
CORS_ORIGIN=http://localhost:5173

# ─── Supabase ──────────────────────────────────────────────
# URL du projet Supabase (Settings > API)
SUPABASE_URL=https://votre-projet.supabase.co

# Clé "service_role" : NE JAMAIS l'exposer côté frontend.
# Utilisée par le backend pour écrire en base et uploader les GPX.
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...

# Clé "anon" (publique) : sert à vérifier les JWT des utilisateurs.
SUPABASE_ANON_KEY=eyJ...anon...

# Nom du bucket Supabase Storage où sont stockés les fichiers GPX.
SUPABASE_GPX_BUCKET=gpx
